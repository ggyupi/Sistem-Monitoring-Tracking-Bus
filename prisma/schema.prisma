// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
  DRIVER
}

enum TransactionType {
  IN
  OUT
  PENALTY
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  RETIRED
}

model User {
  id            String    @id
  name          String
  email         String
  role          UserRole  @default(USER)
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  cards         Card[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// BUS
model Bus {
  id             String  @id @default(cuid())
  busCode        String  @unique
  plateNumber    String
  isActive       Boolean @default(true)
  passengerCount Int     @default(0)

  // Relasi ke Route: Setiap bus terdaftar di satu rute tertentu
  routeId String?
  route   Route?  @relation(fields: [routeId], references: [id])

  passengers       Card[]
  locations        BusLocation[]
  transactions     Transaction[]
  currentIotDevice IotDevice?            @relation("CurrentBusDevice")
  iotAssignments   BusDeviceAssignment[]

  @@map("bus")
}

model IotDevice {
  id            String       @id @default(cuid())
  serialNumber  String       @unique
  deviceKeyHash String       @unique
  status        DeviceStatus @default(ACTIVE)
  firmwareVer   String?
  lastSeenAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  currentBusId String? @unique
  currentBus   Bus?    @relation("CurrentBusDevice", fields: [currentBusId], references: [id])

  assignments BusDeviceAssignment[]

  @@map("iot_device")
}

model BusDeviceAssignment {
  id           String    @id @default(cuid())
  busId        String
  iotDeviceId  String
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?

  bus       Bus       @relation(fields: [busId], references: [id])
  iotDevice IotDevice @relation(fields: [iotDeviceId], references: [id])

  @@index([busId])
  @@index([iotDeviceId])
  @@map("bus_device_assignment")
}

model Card {
  rfidTag  String  @id
  balance  Float   @default(0)
  isInside Boolean @default(false)
  status   String  @default("active")

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  lastBusId String?
  lastBus   Bus?    @relation(fields: [lastBusId], references: [id])

  transactions Transaction[]

  @@map("card")
}

// Update Transaction untuk mencatat di stasiun mana user Tap
model Transaction {
  id        String          @id @default(uuid())
  type      TransactionType
  amount    Float
  latTap    Float?
  lngTap    Float?
  createdAt DateTime        @default(now())

  rfidTag String
  card    Card   @relation(fields: [rfidTag], references: [rfidTag])

  busId String
  bus   Bus    @relation(fields: [busId], references: [id])

  // Opsional: Mencatat nama stasiun saat transaksi terjadi
  stationName String?

  @@map("transaction")
}

model BusLocation {
  id         BigInt   @id @default(autoincrement())
  latitude   Float
  longitude  Float
  speed      Float?
  recordedAt DateTime @default(now())

  busId String
  bus   Bus    @relation(fields: [busId], references: [id])

  @@index([busId])
  @@map("bus_location")
}

model Route {
  id          String   @id @default(cuid())
  routeName   String
  pathGeoJSON Json // Garis kuning trayek
  createdAt   DateTime @default(now())

  buses Bus[]

  // Relasi ke stasiun yang dilewati rute ini
  stations RouteStation[]

  @@map("route")
}

model Station {
  id        String @id @default(cuid())
  name      String // Contoh: "Halte Menur"
  latitude  Float
  longitude Float
  radius    Int    @default(50) // Radius deteksi geofencing (meter)

  // Relasi balik ke rute
  routes RouteStation[]

  @@map("station")
}

// Tabel penengah (Pivot) untuk mengatur urutan halte dalam satu rute
model RouteStation {
  routeId   String
  stationId String
  order     Int    @default(0) // Urutan halte dalam rute

  route   Route   @relation(fields: [routeId], references: [id])
  station Station @relation(fields: [stationId], references: [id])

  @@id([routeId, stationId])
  @@map("route_station")
}
